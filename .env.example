# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/flowdesk_db
# For development, you can also use SQLite:
# DATABASE_URL=sqlite:///app.db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=run.py

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Optional: SMTP Configuration (for sending email invites)
# If not configured, invite links will be returned in API responses
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@flowdesk.com

# Optional: Application Settings
APP_NAME=FlowDesk
APP_URL=http://localhost:5000
